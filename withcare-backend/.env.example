# Copy to .env and fill in. Do NOT commit .env.

# ── Vertex AI / Gemini ───────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GEMINI_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash
FIRESTORE_DATABASE=(default)
GOOGLE_APPLICATION_CREDENTIALS=service-account.json

# ── Google Maps (facility search + distances) ────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ── Google Sign-In (Web OAuth client id; add http://localhost:5173 as an origin) ─
GOOGLE_OAUTH_CLIENT_ID=

# ── Calendar/Drive OAuth ─────────────────────────────────────────────────────
# token.json is generated by scripts/setup_calendar_auth.py (not committed).
GOOGLE_CALENDAR_MCP_URL=

# ── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
# Default is the agentic core. Set USE_AGENT=0 to fall back to the deterministic pipeline.
USE_AGENT=1
